\name{seqToGDS_ANNOVAR}
\alias{seqToGDS_ANNOVAR}
\title{Reformat ANNOVAR VCF}
\description{
    Convert ANNOVAR-annotated VCF output (from \code{table_annovar.pl}) to a
    SeqArray GDS file. Unlike VEP or SnpEff which pack annotations into a
    single pipe-delimited INFO field, ANNOVAR stores each annotation as a
    separate INFO key-value pair. This function imports the VCF via
    \code{seqVCF2GDS}, removes ANNOVAR bookkeeping fields
    (\code{ANNOVAR_DATE}, \code{ALLELE_END}), and optionally adds
    descriptions and type information for known ANNOVAR annotation columns.
}
\usage{
seqToGDS_ANNOVAR(vcf_fn, out_fn, compress=c("LZMA", "ZIP", "none"),
    keep=TRUE, verbose=TRUE)
}
\arguments{
    \item{vcf_fn}{the path(s) of VCF file from ANNOVAR output
        (generated by \code{table_annovar.pl -vcfinput})}
    \item{out_fn}{the file name of output SeqArray GDS file}
    \item{compress}{compression method (LZMA by default), \code{"LZMA"} has
        a higher compression ratio than \code{"ZIP"}}
    \item{keep}{if \code{TRUE} or \code{NA}, keep all ANNOVAR annotation
        nodes in the output GDS file; if \code{FALSE}, remove gene-based
        annotation nodes (Func.*, Gene.*, GeneDetail.*, ExonicFunc.*,
        AAChange.*) after import}
    \item{verbose}{if \code{TRUE}, show information}
}
\value{
    Return the file name of GDS format with an absolute path.
}
\details{
    ANNOVAR's \code{table_annovar.pl} with \code{-vcfinput} adds annotations
    as individual INFO fields in the VCF output, such as
    \code{Func.refGeneWithVer}, \code{Gene.refGeneWithVer},
    \code{ExonicFunc.refGeneWithVer}, \code{AAChange.refGeneWithVer},
    \code{gnomAD_exome_AF}, \code{SIFT_score}, \code{CADD_phred}, etc.
    Each annotation becomes a separate node under \code{annotation/info/}
    in the output GDS file.

    The function automatically removes the \code{ANNOVAR_DATE} and
    \code{ALLELE_END} bookkeeping fields that ANNOVAR adds to the VCF.
    Known ANNOVAR annotation fields are matched against an internal
    metadata table to add descriptions.
}
\references{
    Wang K, Li M, Hakonarson H. ANNOVAR: functional annotation of genetic
variants from high-throughput sequencing data. Nucleic Acids Research,
38(16):e164, 2010. DOI: 10.1093/nar/gkq603.
}

\author{Xiuwen Zheng}
\seealso{
    \code{\link{seqVCF2GDS}}, \code{\link{seqToGDS_VEP}},
    \code{\link{seqToGDS_SnpEff}}
}

\examples{
# ANNOVAR annotation
vcf_fn <- system.file("extdata", "example_wgs_sites_chr22_annovar.vcf.gz",
    package="GDSAnnotator")

seqToGDS_ANNOVAR(vcf_fn, "tmp.gds")

# delete the temporary file
unlink("tmp.gds", force=TRUE)
}

\keyword{gds}
\keyword{annotation}
\keyword{WGS}
\keyword{ANNOVAR}
